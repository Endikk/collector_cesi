{
    "name": "collector-root",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "backend",
        "frontend"
    ],
    "scripts": {
        "dev": "dotenv -e .env -- concurrently \"npm run dev --workspace=frontend\" \"npm run start:dev --workspace=backend\"",
        "db:seed:admin": "dotenv -e .env -- ts-node scripts/db/create-admin.ts",
        "db:seed:categories": "dotenv -e .env -- ts-node scripts/db/seed-categories.ts",
        "db:sync": "dotenv -e .env -- node scripts/utils/sync-prisma.js",
        "infra:minikube": "bash scripts/infra/setup-minikube.sh",
        "infra:demo": "bash scripts/infra/demo-scalability.sh",
        "test": "dotenv -e .env -- concurrently \"npm run test --workspace=frontend\" \"npm run test --workspace=backend\"",
        "test:load": "bash scripts/test/load-test.sh",
        "test:k6:load": "bash scripts/test/load/run-k6.sh load-test",
        "test:k6:stress": "bash scripts/test/load/run-k6.sh stress-test",
        "test:k6:spike": "bash scripts/test/load/run-k6.sh spike-test",
        "lint": "dotenv -e .env -- concurrently \"npm run lint --workspace=frontend\" \"npm run lint --workspace=backend\"",
        "build": "dotenv -e .env -- concurrently \"npm run build --workspace=frontend\" \"npm run build --workspace=backend\"",
        "setup:notifications": "dotenv -e .env -- bash scripts/setup/setup-notifications.sh"
    },
    "devDependencies": {
        "@types/jest": "^30.0.0",
        "concurrently": "^8.2.2",
        "dotenv-cli": "^11.0.0",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^30.2.0",
        "prisma": "5.22.0",
        "ts-jest": "^29.1.2",
        "ts-node": "^10.9.2",
        "typescript": "^5.3.3"
    },
    "overrides": {
        "braces": "^3.0.3",
        "micromatch": "^4.0.8",
        "ws": "^8.18.0",
        "cross-spawn": "^7.0.6",
        "path-to-regexp": "^3.3.0",
        "qs": "^6.14.2",
        "form-data": "^2.5.4",
        "tough-cookie": "^4.1.4",
        "minimist": "^1.2.8",
        "node-notifier": "^8.0.2",
        "tmp": "^0.2.3",
        "webpack": "^5.94.0",
        "minimatch": "^3.1.2",
        "glob-parent": "^5.1.2"
    },
    "dependencies": {
        "@prisma/client": "^5.22.0"
    }
}