    },
    {
      
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 95 },
              { "color": "green", "value": 99 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "background_solid",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "🟢 Disponibilité (SLA)",
      "description": "Pourcentage de requêtes sans erreur 5xx sur les dernières 24h",
      "type": "stat",
      "targets": [
        {
          "expr": "((sum(rate(http_requests_total{status_code!~\"5..\"}[24h])) / sum(rate(http_requests_total[24h]))) * 100) OR vector(100)",
          "legendFormat": "Uptime",
          "refId": "A"
        }
      ]
    },
    {
      
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "orange", "value": 500 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background_solid",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "📈 Requêtes / minute",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[5m])) * 60",
          "legendFormat": "Req/min",
          "refId": "A"
        }
      ]
    },
    {
      
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
